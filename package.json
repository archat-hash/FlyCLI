{
  "name": "flycli",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "bin": {
    "flycli": "./index.js"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:bdd": "node --experimental-vm-modules node_modules/.bin/cucumber-js test/bdd/general/*.feature --import 'test/bdd/shared_steps/*.js'",
    "test:hw": "node --experimental-vm-modules node_modules/.bin/cucumber-js test/bdd/firmware/v4.3.x/*.feature --import 'test/bdd/shared_steps/*.js' --import 'test/bdd/firmware/v4.3.x/*.js'",
    "test:full": "npm run test && npm run test:bdd && npm run test:hw",
    "pretest": "npm run lint",
    "lint": "eslint .",
    "prepare": "npm run lint"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@jest/globals": "^30.3.0",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0"
  }
}
